{
  "expo": {
    "name": "Hhousing Tenant",
    "slug": "hhousing-mobile-tenant",
    "scheme": "hhousing-tenant",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hhousing.tenant",
      "associatedDomains": [
        "applinks:harakaproperty.com",
        "applinks:www.harakaproperty.com"
      ]
    },
    "android": {
      "package": "com.hhousing.tenant",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "harakaproperty.com",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "www.harakaproperty.com",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
