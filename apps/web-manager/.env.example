# web-manager environment variables (copy to .env.local or Vercel)

# Public site URL (use https://www.harakaproperty.com in production)
NEXT_PUBLIC_APP_URL=https://www.harakaproperty.com
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=contact@harakaproperty.com
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@harakaproperty.com

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# WhatsApp Business Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v25.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_TENANT_INVITATION_TEMPLATE=tenant_invitation_v1
WHATSAPP_TENANT_INVITATION_TEMPLATE_LANGUAGE=fr
WHATSAPP_LEASE_DOCUMENTS_TEMPLATE=lease_documents_v1
WHATSAPP_LEASE_DOCUMENTS_TEMPLATE_LANGUAGE=fr
WHATSAPP_PAYMENT_CONFIRMATION_TEMPLATE=payment_confirmation_v1
WHATSAPP_PAYMENT_CONFIRMATION_TEMPLATE_LANGUAGE=fr
NOTIFICATION_DEFAULT_CHANNELS=email,whatsapp

# PawaPay mobile money (server-side only)
PAWAPAY_API_TOKEN=
PAWAPAY_TOKEN_ID=
PAWAPAY_API_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_ENV=sandbox
PAWAPAY_DEFAULT_COUNTRY=COD
