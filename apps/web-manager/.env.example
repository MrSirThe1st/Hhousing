# web-manager environment variables (copy to .env.local or Vercel)

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# WhatsApp Business Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v25.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_TENANT_INVITATION_TEMPLATE=tenant_invitation_v1
WHATSAPP_TENANT_INVITATION_TEMPLATE_LANGUAGE=fr
NOTIFICATION_DEFAULT_CHANNELS=email,whatsapp

# PawaPay mobile money (server-side only)
PAWAPAY_API_TOKEN=
PAWAPAY_TOKEN_ID=
PAWAPAY_API_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_ENV=sandbox
PAWAPAY_DEFAULT_COUNTRY=COD
